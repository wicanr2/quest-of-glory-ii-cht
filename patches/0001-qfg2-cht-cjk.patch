+// Blit one CJK atlas glyph (size x size, 8-bit coverage) using text_color.
+// Mirrors RenderChar's clipping. Returns horizontal advance in pixels.
+// NOTE: coverage is thresholded to 1-bit. Proper alpha anti-aliasing needs the
+// destination bitmap's own pixel format (the global allegro 32-bit shifts used
+// by makeacol32 do not match every surface), so it is left for future work.
+static int RenderCjkGlyph(Bitmap *ds, const int at_x, const int at_y, Rect clip,
+		const CjkGlyph &glyph, const int size, const color_t text_color) {
+	const byte *cov = &glyph.Coverage[0];
+	int sx = MAX(at_x, (int)clip.Left), ex = clip.Right + 1;
+	int sy = MAX(at_y, (int)clip.Top), ey = clip.Bottom + 1;
+	int sw = MAX(0, (int)clip.Left - at_x);
+	int sh = MAX(0, (int)clip.Top - at_y);
+	for (int h = sh, y = sy; h < size && y < ey; ++h, ++y) {
+		for (int w = sw, x = sx; w < size && x < ex; ++w, ++x) {
+			if (cov[h * size + w] >= 0x80)
+				ds->PutPixel(x, y, text_color);
+		}
+	}
+	return glyph.Advance;
+}
