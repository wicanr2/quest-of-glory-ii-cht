+void cht_cycle_language_mode() {
+	// Cycle: 0 = 繁中 16x16, 1 = 繁中 24x24, 2 = English(原文).
+	static int mode = 0;
+	mode = (mode + 1) % 3;
+	const char *name;
+	if (mode == 0) {
+		g_cht_translation_on = true;
+		cht_set_cjk_enabled(true);
+		cht_set_cjk_size(16);
+		name = "\xE7\xB9\x81\xE4\xB8\xAD 16x16";
+		g_cht_lang_suffix = " (\xE7\xB9\x81\xE4\xB8\xAD16)";
+	} else if (mode == 1) {
+		g_cht_translation_on = true;
+		cht_set_cjk_enabled(true);
+		cht_set_cjk_size(24);
+		name = "\xE7\xB9\x81\xE4\xB8\xAD 24x24";
+		g_cht_lang_suffix = " (\xE7\xB9\x81\xE4\xB8\xAD24)";
+	} else {
+		g_cht_translation_on = false;
+		cht_set_cjk_enabled(false);
+		name = "English";
+		g_cht_lang_suffix = "";
+	}
+	// Recompute every font's metrics so line spacing matches the new glyph size.
+	for (size_t i = 0; i < _GP(fonts).size(); ++i)
+		font_recalc_metrics(i);
+	cht_room_bg_apply();   // CHT:F8 切語言時 room 背景中文版/原版跟著切(保留原圖)
+	// CHT:讓走 .tra 的 GUI 文字(頂部遊戲名標題等)跟著重繪,否則 F8 切換後標題會卡在舊語言
+	AGS::Shared::GUI::MarkForTranslationUpdate();
+	Debug::Printf(kDbgMsg_Info, "CHT: language mode -> %s", name);
+}
+
