+// True if the text contains at least one full-width CJK glyph present in the
+// atlas. On such a (mixed) line we route ASCII through the atlas too, so the
+// inline Latin matches the Chinese in size and baseline.
+static bool cht_line_has_cjk(const char *text, CjkFont *cjk) {
+	if (!cjk)
+		return false;
+	for (int code = ugetxc(&text); code; code = ugetxc(&text)) {
+		if (code >= 0x2000 && cjk->Get((uint32)code))
+			return true;
+	}
+	return false;
+}
