+// CHT:簡易 UTF-8 解碼(中文 3 bytes),供 room overlay 用。
+static uint32 cht_utf8_next(const char **p) {
+	const unsigned char *s = (const unsigned char *)*p;
+	if (s[0] < 0x80) { if (s[0]) (*p)++; return s[0]; }
+	if ((s[0] & 0xE0) == 0xC0) { *p += 2; return ((s[0] & 0x1F) << 6) | (s[1] & 0x3F); }
+	if ((s[0] & 0xF0) == 0xE0) { *p += 3; return ((s[0] & 0x0F) << 12) | ((s[1] & 0x3F) << 6) | (s[2] & 0x3F); }
+	(*p)++; return 0;
+}
