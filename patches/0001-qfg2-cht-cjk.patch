+// 依當前語言把 BgFrames[0] 換成中/英版(get_cjk_font 非 null=中文模式);room 載入後 + F8 呼叫。
+void cht_room_bg_apply() {
+	if (g_cht_bg_room != _G(displayed_room) || !g_cht_cht_bg || !g_cht_orig_bg)
+		return;
+	if (_GP(thisroom).BgFrameCount == 0 || !_GP(thisroom).BgFrames[0].Graphic)
+		return;
+	AGS::Shared::Bitmap *src = (get_cjk_font() != nullptr) ? g_cht_cht_bg : g_cht_orig_bg;
+	AGS::Shared::Bitmap *dst = _GP(thisroom).BgFrames[0].Graphic.get();
+	const int H = dst->GetHeight();
+	// 只 blit 左右欄屬性名區(中間職業/拱門 + 數值框不動,保留 script 已畫的數值)
+	dst->Blit(src, 0, 28, 0, 28, 89, H - 28);        // 左欄屬性名(左數值框 x91 起,避開以保留 script 畫的數值)
+	dst->Blit(src, 195, 28, 195, 28, 86, H - 28);    // 右欄屬性名(右數值框 x282 起,避開以保留數值)
+	_GP(play).raw_modified[0] = 1;
+	invalidate_screen();
+	mark_current_background_dirty();   // 觸發 room 背景重繪(F8 切換時畫面才更新)
+}
