+// CHT:把重繪的中文 button 圖(cht_btnsprites.bin)注入 spriteset,替換對應 sprite。
+// 角色創建職業 button 等是美術 sprite(button 圖上印英文字),無法走 .tra,
+// 只能換圖。格式:int32 count + 每個[int32 idx, int32 w, int32 h, w*h*4 BGRA]。
+// 中文模式(get_cjk_font 非 null)才替換;F8 切英文不影響(已載入的 sprite 保持)。
+void cht_load_button_sprites() {
+	if (get_cjk_font() == nullptr)
+		return;
+	Common::File f;
+	if (!f.open("cht_btnsprites.bin"))
+		return;
+	int count = f.readSint32LE();
+	int loaded = 0;
+	for (int i = 0; i < count && !f.eos(); ++i) {
+		int idx = f.readSint32LE();
+		int w = f.readSint32LE();
+		int h = f.readSint32LE();
+		if (w <= 0 || h <= 0 || w > 4096 || h > 4096)
+			break;
+		AGS::Shared::Bitmap *bm = AGS::Shared::BitmapHelper::CreateBitmap(w, h, 32);
+		if (!bm)
+			break;
+		for (int y = 0; y < h; ++y)
+			f.read(bm->GetScanLineForWriting(y), w * 4);
+		if (_GP(spriteset).SetSprite(idx, std::unique_ptr<AGS::Shared::Bitmap>(bm)))
+			++loaded;
+	}
+	f.close();
+	warning("CHT: injected %d button sprite(s)", loaded);
+}
