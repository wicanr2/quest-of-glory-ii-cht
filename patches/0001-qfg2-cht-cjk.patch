+namespace AGS3 {
+
+using namespace AGS::Shared;
+
+bool CjkFont::Load(const char *filename) {
+	Stream *in = _GP(AssetMgr)->OpenAsset(filename);
+	if (in == nullptr)
+		return false;
+
+	char magic[4] = { 0 };
+	in->Read(magic, 4);
+	if (magic[0] != 'C' || magic[1] != 'J' || magic[2] != 'K' || magic[3] != 'F') {
+		delete in;
+		return false;
+	}
+	_size = in->ReadInt32();
+	int count = in->ReadInt32();
+	if (_size <= 0 || _size > 64 || count <= 0) {
+		delete in;
+		_size = 0;
+		return false;
+	}
+	const int bytes = _size * _size;
+	for (int i = 0; i < count; ++i) {
+		uint32 code = (uint32)in->ReadInt32();
+		CjkGlyph glyph;
+		glyph.Advance = in->ReadInt32();
+		glyph.Coverage.resize(bytes);
+		in->Read(&glyph.Coverage[0], bytes);
+		_glyphs[code] = glyph;
+	}
+	delete in;
+	Debug::Printf(kDbgMsg_Info, "CJK: loaded %d glyphs @ %dpx from %s", (int)_glyphs.size(), _size, filename);
+	return IsValid();
+}
+
+static CjkFont *s_font = nullptr;
+static int s_size = 0;        // currently loaded glyph size (16/24); 0 = none
+static bool s_enabled = true; // false in English mode
+
+static bool cht_load_size(int size) {
+	const char *fn = (size == 24) ? "cjkfont24.bin" : "cjkfont16.bin";
+	CjkFont *f = new CjkFont();
+	if (f->Load(fn)) {
+		delete s_font;
+		s_font = f;
+		s_size = size;
+		return true;
+	}
+	delete f;
+	return false;
+}
+
+void cht_set_cjk_size(int size) {
+	if (size != 16 && size != 24)
+		return;
+	if (size == s_size && s_font)
+		return;
+	cht_load_size(size);
+}
+
+int cht_get_cjk_size() {
+	return s_size;
+}
+
+void cht_set_cjk_enabled(bool on) {
+	s_enabled = on;
+}
+
+CjkFont *get_cjk_font() {
+	static bool s_init = false;
+	if (!s_init) {
+		s_init = true;
+		// ConfMan "ags_cjk_size" picks the initial glyph size (16 or 24).
+		// 16 is the safe default (fits 320x200 text boxes); 24 is crisper but
+		// long auto-sized Display boxes may overflow at native resolution.
+		int pref = ConfMan.hasKey("ags_cjk_size") ? ConfMan.getInt("ags_cjk_size") : 16;
+		if (!cht_load_size(pref == 24 ? 24 : 16))
+			cht_load_size(pref == 24 ? 16 : 24); // fall back to the other size
+	}
+	return s_enabled ? s_font : nullptr;
+}
+
+// CHT:status bar 遊戲名標題(font 0)專用的小字級 CJK。原版標題是矮 status bar
+// 的小英文(字高 7),套 16px 中文過大不協調;改用 12px 點陣讓標題接近原版比例。
+// 英文模式(s_enabled=false)回 null,標題走原文。載不到 cjkfont12.bin 就退回一般字級。
+CjkFont *get_cjk_title_font() {
+	if (!s_enabled)
+		return nullptr;
+	static CjkFont *s_title = nullptr;
+	static bool s_tried = false;
+	if (!s_title && !s_tried) {
+		s_tried = true;
+		CjkFont *f = new CjkFont();
+		if (f->Load("cjkfont12.bin"))
+			s_title = f;
+		else
+			delete f;
+	}
+	return s_title ? s_title : get_cjk_font();
+}
+
+} // namespace AGS3
