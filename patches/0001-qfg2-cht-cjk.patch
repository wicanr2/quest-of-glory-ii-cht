+//=============================================================================
+//
+// CJK bitmap glyph atlas for the Traditional-Chinese localization patch.
+// Loaded once from "cjkfontNN.bin" (baked by tools/build_cjk_font.py) and
+// queried by the WFN/TTF renderers to draw multi-byte (UTF-8) codepoints.
+// English/ASCII text is unaffected: only codepoints present in the atlas
+// are drawn from here, everything else falls through to the original font.
+//
+//=============================================================================
+
+#ifndef AGS_SHARED_FONT_CJK_FONT_H
+#define AGS_SHARED_FONT_CJK_FONT_H
+
+#include "common/hashmap.h"
+#include "common/array.h"
+
+namespace AGS3 {
+
+struct CjkGlyph {
+	int Advance = 0;              // 水平前進寬(全形=size,ASCII=比例半寬)
+	Common::Array<byte> Coverage; // size*size, 0..255
+};
+
+class CjkFont {
+public:
+	bool Load(const char *filename);
+	bool IsValid() const { return _size > 0 && _glyphs.size() > 0; }
+	int Size() const { return _size; }
+	// returns nullptr if the codepoint is not in the atlas
+	const CjkGlyph *Get(uint32 code) const {
+		Common::HashMap<uint32, CjkGlyph>::const_iterator it = _glyphs.find(code);
+		return (it == _glyphs.end()) ? nullptr : &it->_value;
+	}
+
+private:
+	int _size = 0;
+	Common::HashMap<uint32, CjkGlyph> _glyphs;
+};
+
+// Lazily loads cjkfontNN.bin via the asset manager; returns nullptr if absent
+// or if the CJK overlay is currently disabled (English mode). Cached.
+CjkFont *get_cjk_font();
+CjkFont *get_cjk_title_font();   // CHT:font 0(status bar 標題)專用的小字級 CJK(12px)
+
+// Runtime control for the in-game F8 language toggle.
+void cht_set_cjk_size(int size);     // 16 or 24; reloads the atlas
+int  cht_get_cjk_size();             // currently loaded size (0 if none)
+void cht_set_cjk_enabled(bool on);   // false = English mode (get_cjk_font -> null)
+
+} // namespace AGS3
+
+#endif
