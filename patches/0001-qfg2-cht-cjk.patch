+// CHT:room 背景中文化。角色創建屬性名是烘在 room 原始背景圖上的美術字,host 用
+// OpenCV inpaint 把英文區卷軸紋理補回 + 畫中文,產出中文版 bin(cht_roombg<N>.bin)。
+// 引擎在 room 載入後:保存原版 copy、載入中文版,依當前語言(F8)替換 BgFrames[0],
+// 切英文時還原原版(保留原圖、不破壞,F8 可來回切)。
+static AGS::Shared::Bitmap *g_cht_orig_bg = nullptr;  // 原版 bg(英文) copy
+static AGS::Shared::Bitmap *g_cht_cht_bg = nullptr;   // 中文版 bg(讀 bin)
+static int g_cht_bg_room = -1;
+
+void cht_room_text_overlay() {
+	if (_GP(thisroom).BgFrameCount == 0 || !_GP(thisroom).BgFrames[0].Graphic)
+		return;
+	const int room = _G(displayed_room);
+	AGS::Shared::Bitmap *bg = _GP(thisroom).BgFrames[0].Graphic.get();
+	// dump 乾淨原版 bg(overlay 前、script 畫數值前)供 host OpenCV inpaint 美術重繪
+	if (ConfMan.hasKey("ags_dump_static", ConfMan.getActiveDomainName())) {
+		Common::String op = ConfMan.get("ags_dump_static", ConfMan.getActiveDomainName());
+		op += Common::String::format(".origbg%d.raw", _G(displayed_room));
+		FILE *of = fopen(op.c_str(), "wb");
+		if (of) {
+			int ow = bg->GetWidth(), oh = bg->GetHeight(), obpp = bg->GetBPP();
+			fwrite(&ow, 4, 1, of); fwrite(&oh, 4, 1, of); fwrite(&obpp, 4, 1, of);
+			for (int yy = 0; yy < oh; ++yy)
+				fwrite(bg->GetScanLine(yy), bg->GetLineLength(), 1, of);
+			fclose(of);
+		}
+	}
+	// 首次進此 room:載入中文版 bin(int32 w,h + BGRA) + 保存原版 copy
+	if (g_cht_bg_room != room) {
+		delete g_cht_orig_bg; g_cht_orig_bg = nullptr;
+		delete g_cht_cht_bg; g_cht_cht_bg = nullptr;
+		g_cht_bg_room = room;
+		Common::File f;
+		if (f.open(Common::Path(Common::String::format("cht_roombg%d.bin", room)))) {
+			int bw = f.readSint32LE(), bh = f.readSint32LE();
+			if (bw == bg->GetWidth() && bh == bg->GetHeight() && bg->GetColorDepth() == 32) {
+				g_cht_cht_bg = AGS::Shared::BitmapHelper::CreateBitmap(bw, bh, 32);
+				for (int yy = 0; yy < bh; ++yy)
+					f.read(g_cht_cht_bg->GetScanLineForWriting(yy), bw * 4);
+				g_cht_orig_bg = AGS::Shared::BitmapHelper::CreateBitmapCopy(bg);
+			}
+			f.close();
+		}
+	}
+	cht_room_bg_apply();
+}
