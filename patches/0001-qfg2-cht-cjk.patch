+// CHT patch (dev-only): when ConfMan boolean "ags_dump_strings" is set, append
+// every source string passed to get_translation() to a file, so we can collect
+// the exact translatable keys (milestone M2). Off by default; no effect on players.
+static void cht_dump_source_string(const char *text) {
+	// ConfMan string "ags_dump_strings" = output file path (checked across domains).
+	static int s_state = 0; // 0=unknown 1=on 2=off
+	static FILE *s_dump = nullptr;
+	if (s_state == 0) {
+		Common::String path;
+		if (!(ConfMan.hasKey("ags_dump_strings", ConfMan.getActiveDomainName()) &&
+		      !(path = ConfMan.get("ags_dump_strings", ConfMan.getActiveDomainName())).empty()))
+			path.clear();
