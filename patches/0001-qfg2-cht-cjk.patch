+// CHT 靜態抽取(M2):走訪已載入的資料結構,把可翻譯字串吐成檔(供翻譯)。
+// 重用引擎自己 parse 好的結構,不必自寫 MFL/script 解析器。
+// 由 ConfMan 字串 "ags_dump_static"(=輸出路徑)觸發;玩家 build 無作用。
+static void cht_dump_script_strings(FILE *f, const ccScript *scr) {
+	if (!scr || !scr->strings || scr->stringssize <= 0)
+		return;
+	const char *p = scr->strings;
+	const char *end = scr->strings + scr->stringssize;
+	while (p < end) {
+		size_t len = strlen(p);
+		if (len > 0)
+			fprintf(f, "%s\n", p);
+		p += len + 1;
+	}
+}
