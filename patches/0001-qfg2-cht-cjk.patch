+		s_state = s_dump ? 1 : 2;
+		warning("CHT-DIAG: get_translation alive; dump path='%s' open=%d", path.c_str(), (int)(s_state == 1));
+	}
+	if (s_state == 1) {
+		fprintf(s_dump, "%s\n", text);
+		fflush(s_dump);
+	}
+}
