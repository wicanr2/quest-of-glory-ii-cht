+// CHT: Android 系統鍵盤同步 —— AGS 原生不呼叫 kFeatureVirtualKeyboard,手機上遇到
+// 遊戲內文字輸入(如 QFG2 建角色輸入姓名的 GUITextBox)系統鍵盤不會自動跳出、打不了字。
+// 每幀偵測「有可見且啟用的 GUITextBox 在等輸入」,對應開/關虛擬鍵盤(狀態變化才呼叫)。
+// 桌面平台 setFeatureState(kFeatureVirtualKeyboard) 為 no-op,不影響。
+static void cht_sync_virtual_keyboard() {
+	bool wantTextInput = false;
+	if (_G(all_buttons_disabled) < 0) {
+		for (int gi = 0; gi < _GP(game).numgui && !wantTextInput; ++gi) {
+			auto &gui = _GP(guis)[gi];
+			if (!gui.IsDisplayed())
+				continue;
+			for (int ci = 0; ci < gui.GetControlCount(); ++ci) {
+				if (gui.GetControlType(ci) != kGUITextBox)
+					continue;
+				auto *tb = static_cast<GUITextBox *>(gui.GetControl(ci));
+				if (tb && tb->IsEnabled() && tb->IsVisible()) {
+					wantTextInput = true;
+					break;
+				}
+			}
+		}
+	}
+	static bool s_vkeybd_on = false;
+	if (wantTextInput != s_vkeybd_on) {
+		s_vkeybd_on = wantTextInput;
+		g_system->setFeatureState(OSystem::kFeatureVirtualKeyboard, wantTextInput);
+	}
+}
